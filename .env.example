PORT=5000
NODE_ENV=development

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dweaver

ACCESS_TOKEN_SECRET=your_access_token_secret
CLIENT_URL=http://localhost:3000

AI_CHUNK_MAX_ESTIMATED_TOKENS=250000

AI_JOB_MAX_ATTEMPTS=5
AI_VALIDATION_MAX_ATTEMPTS=9
AI_NETWORK_MAX_RETRIES=3

AI_TRANSIENT_RETRY_DELAY_MS=300000
AI_TRANSIENT_RETRY_MAX_DELAY_MS=1800000

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=420000

GEMINI_RPM_LIMIT=5
GEMINI_TPM_LIMIT=250000
GEMINI_RPD_LIMIT=20

AZURE_SPEECH_KEY=your_key_here
AZURE_SPEECH_REGION=your_region_here
